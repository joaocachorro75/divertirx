# Divertirx - Configurações

# ============================================
# PROVEDOR DE IA (escolha um)
# Opções: groq, openrouter, openai
# ============================================
AI_PROVIDER=groq
AI_MODEL=llama-3.3-70b-versatile

# Chaves de API (preencha a do provedor escolhido)
GROQ_API_KEY=gsk_sua_chave_aqui
OPENROUTER_API_KEY=sk-or-v1-sua_chave_aqui
OPENAI_API_KEY=sk-sua_chave_aqui

# ============================================
# PAINÉIS DE SERVIÇOS
# ============================================

# OnPix (TV)
ONPIX_PROXY=5.161.155.252:80
ONPIX_USERNAME=seu_usuario_onpix
ONPIX_PASSWORD=sua_senha_onpix

# ServX (Internet VPN)
SERVEX_API_KEY=sx_sua_chave_api_aqui

# ============================================
# CONFIGURAÇÕES GERAIS
# ============================================
NODE_ENV=production
PORT=3000
NEXT_PUBLIC_APP_URL=https://seu-dominio.com
